<section class="py-section-gap px-6 md:px-margin-edge bg-primary-container text-surface overflow-hidden relative" id="contacto">
  <div class="absolute inset-0 opacity-10 pointer-events-none"></div>
  <div class="max-w-container-max mx-auto grid grid-cols-12 gap-gutter relative z-10">
    <div class="col-span-12 md:col-span-5 mb-12 md:mb-0 reveal-on-scroll">
      <p class="font-label-sm text-label-sm uppercase tracking-[0.3em] text-secondary-fixed-dim mb-4 md:mb-6">
        Compromiso
      </p>
      <h2 class="font-headline-lg text-display-xl-mobile md:text-headline-lg mb-6 md:mb-10 leading-tight">
        Agende una sesión estratégica corporativa.
      </h2>
      <p class="font-body-lg text-primary-fixed-dim mb-8 md:mb-12">
        Nuestra respuesta es inmediata y bajo estricto protocolo de confidencialidad.
      </p>
      <div class="space-y-4 md:space-y-6">
        <div class="flex items-center space-x-3 md:space-x-4">
          <span class="material-symbols-outlined text-secondary-fixed-dim">location_on</span>
          <span class="font-body-md tracking-wide">Avenida Reforma 9-55, Zona 10, Ciudad de Guatemala</span>
        </div>
        <div class="flex items-center space-x-3 md:space-x-4">
          <span class="material-symbols-outlined text-secondary-fixed-dim">mail</span>
          <span class="font-body-md tracking-wide">privado@estudiolegal.gt</span>
        </div>
      </div>
    </div>
    <div class="col-span-12 md:col-start-7 md:col-span-6 reveal-on-scroll">
      <form class="space-y-8 md:space-y-12" action="mailto:privado@estudiolegal.gt" method="post" enctype="text/plain">
        <div class="group">
          <label class="font-label-sm text-label-sm uppercase tracking-widest text-primary-fixed-dim mb-2 block">Nombre Completo</label>
          <input
            class="w-full bg-transparent border-b border-primary-fixed-dim/30 py-4 focus:outline-none focus:border-secondary-fixed-dim transition-colors placeholder:text-primary-fixed-dim/20"
            placeholder="Su nombre y apellidos"
            type="text"
            name="nombre"
          />
        </div>
        <div class="group">
          <label class="font-label-sm text-label-sm uppercase tracking-widest text-primary-fixed-dim mb-2 block">Organización</label>
          <input
            class="w-full bg-transparent border-b border-primary-fixed-dim/30 py-4 focus:outline-none focus:border-secondary-fixed-dim transition-colors placeholder:text-primary-fixed-dim/20"
            placeholder="Entidad legal o firma"
            type="text"
            name="organizacion"
          />
        </div>
        <div class="group">
          <label class="font-label-sm text-label-sm uppercase tracking-widest text-primary-fixed-dim mb-2 block">Naturaleza de la Consulta</label>
          <select class="w-full bg-transparent border-b border-primary-fixed-dim/30 py-4 focus:outline-none focus:border-secondary-fixed-dim transition-colors text-primary-fixed-dim/60" name="consulta">
            <option class="bg-primary-container">Seleccione un área de práctica</option>
            <option class="bg-primary-container">Derecho Corporativo</option>
            <option class="bg-primary-container">Protección Patrimonial</option>
            <option class="bg-primary-container">Propiedad Intelectual</option>
            <option class="bg-primary-container">Otros Asuntos</option>
          </select>
        </div>
        <button
          type="submit"
          class="w-full md:w-auto bg-surface text-primary px-10 md:px-16 py-4 md:py-5 font-nav-link text-nav-link tracking-[0.2em] uppercase hover:bg-secondary-fixed-dim transition-all duration-300"
        >
          Enviar Solicitud
        </button>
      </form>
    </div>
  </div>
</section>
